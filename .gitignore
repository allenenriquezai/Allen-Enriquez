# Secrets — never commit these
.env
credentials.json
credentials_*.json
token.json
token.pickle
token_*.pickle
projects/**/.env
projects/personal/credentials_personal.json
projects/personal/token_personal.pickle

# Temporary processing files
.tmp/
projects/**/.tmp/

# Shared (personal — keep off remote)
/shared/

# Dashboard SQLite cache
tools/dashboard/dashboard.db

# Enriquez2.0 raw ingestion (gitignored, regenerable)
tools/enriquez2.0/raw/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# GSD planning artifacts
.planning/

# TLS certs (local dev only)
*.pem

# Media files (not code)
*.mov
*.mp4
*.png
*.jpg
*.jpeg

# SQLite temp files
*.db-shm
*.db-wal

# macOS
.DS_Store
node_modules/

# Service virtualenvs
services/**/.venv/
services/**/__pycache__/
