<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.enriquezOS.estimateone-scraper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd /Users/allenenriquez/Desktop/Allen\ Enriquez &amp;&amp; /usr/bin/python3 tools/estimateone_scraper.py --all &amp;&amp; /usr/bin/python3 tools/e1_to_sheet.py</string>
