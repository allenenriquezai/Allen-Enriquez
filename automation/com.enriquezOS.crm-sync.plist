<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.enriquezOS.crm-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/allenenriquez/Developer/Allen-Enriquez/tools/eps/crm_sync.py</string>
    </array>

    <!-- Every 10 minutes -->
    <key>StartInterval</key>
    <integer>600</integer>

    <key>StandardOutPath</key>
    <string>/Users/allenenriquez/Developer/Allen-Enriquez/.tmp/crm-sync.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/allenenriquez/Developer/Allen-Enriquez/.tmp/crm-sync-error.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/allenenriquez/Developer/Allen-Enriquez</string>

    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
